        {
          "command": "MI.test.edit.mock-service",
          "group": "inline",
          "when": "view == MI.mock-services && viewItem == mockService"
        },
        {
          "command": "MI.test.delete.mock-service",
          "group": "inline",
          "when": "view == MI.mock-services"
        }
      ],
      "testing/item/context": [
