{
  "name": "Payload",
  "type": "mediator",
  "title": "Payload Mediator",
  "canTryOut": true,
  "help": "Replaces message payload with a new payload.",
  "elements": [
    {
      "type": "attribute",
      "value": {
        "name": "mediaType",
        "displayName": "Content Type",
        "inputType": "combo",
        "defaultValue": "json",
        "comboValues": [
          "xml",
          "json",
          "text"
        ],
        "required": false,
        "helpTip": "Content type of the constructed payload."
      }
    },
    {
      "type": "attributeGroup",
      "value": {
        "groupName": "Payload",
        "elements": [
          {
            "type": "attribute",
            "value": {
              "name": "payload",
              "displayName": "Payload",
              "inputType": "expressionTextArea",
              "defaultValue": "",
              "required": true,
              "enableCondition": [
                {
                  "useTemplateResource": false
                }
              ],
              "helpTip": "Template used to construct the payload. You can use any expression like {\"id\": \"${var.userID}\", \"content\": ${payload.user.data}}",
              "placeholder": {
                "conditionField": "mediaType",
                "values": [
                  {
                    "xml": "<inline/>"
                  },
                  {
                    "json": "{\"Inline\":\"json\"}"
                  },
                  {
                    "text": "Inline text"
                  }
                ]
              }
            }
          }
        ]
      }
    },
    {
      "type": "attributeGroup",
      "value": {
        "groupName": "Advanced configurations",
        "isCollapsed": true,
        "elements": [
          {
            "type": "attribute",
            "value": {
              "name": "templateType",
              "displayName": "Template Type",
              "inputType": "combo",
              "defaultValue": "default",
              "comboValues": [
                "default",
                "freemarker"
              ],
              "required": false,
              "helpTip": "Template type used to construct the payload."
            }
          },
          {
            "type": "attribute",
            "value": {
              "name": "useTemplateResource",
              "displayName": "Use a Template Resource",
              "inputType": "checkbox",
              "defaultValue": false,
              "required": false,
              "helpTip": ""
            }
          },
          {
            "type": "attribute",
            "value": {
              "name": "payloadKey",
              "displayName": "Resource Key",
              "inputType": "resource",
              "keyType": [
                "xml",
                "json",
                "txt",
                "ftl"
              ],
              "required": true,
              "helpTip": "",
              "enableCondition": [
                {
                  "useTemplateResource": true
                }
              ],
              "canAddNew": true
            }
          }
        ]
      }
    },
    {
      "type": "attribute",
      "value": {
        "name": "traceFilter",
        "displayName": "Enable Trace Filter",
        "inputType": "checkbox",
        "defaultValue": "false",
        "helpTip": "Enable Trace Filter",
        "required": "false"
      }
    },
    {
      "type": "attribute",
      "value": {
        "name": "description",
        "displayName": "Description",
        "inputType": "string",
        "defaultValue": "",
        "required": false,
        "helpTip": ""
      }
    }
  ]
}
